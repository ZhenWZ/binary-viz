{
  "manifest_version": 3,
  "name": "Binary Data Visualizer",
  "description": "Decode and visualize PyTorch & NumPy binary dumps directly in Chrome",
  "version": "1.1.0",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    },
    "default_title": "Binary Data Visualizer"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": []
}
